        "model_final_norm": {
            "gguf_name": "output_norm.weight",
            "q4nx_name": "model.norm.weight",
            "default_tensor_type": "BF16"             
        },
        "rope_freqs": {
            "gguf_name": "rope_freqs.weight",
            "q4nx_name": "rope_freqs.weight"
        },
        "lm_head": {
            "gguf_name": "output.weight",
            "q4nx_name": "lm_head.weight"
        }
    }
}