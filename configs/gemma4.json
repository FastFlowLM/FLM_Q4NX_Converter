            "default_tensor_type": "BF16"            
        },
        "post_norm": {
            "gguf_name": "blk.{bid}.post_norm.weight",
            "q4nx_name": "model.layers.{bid}.post_layernorm.weight",
            "default_tensor_type": "BF16"                        
        },        
        "up_proj": {
            "gguf_name": "blk.{bid}.ffn_up.weight",
            "q4nx_name": "model.layers.{bid}.mlp.up_proj.weight"                        
        },
        "gate_proj": {
            "gguf_name": "blk.{bid}.ffn_gate.weight",
            "q4nx_name": "model.layers.{bid}.mlp.gate_proj.weight"
        },
        "down_proj": {
            "gguf_name": "blk.{bid}.ffn_down.weight",
            "q4nx_name": "model.layers.{bid}.mlp.down_proj.weight"
        },
        "attn_norm": {
            "gguf_name": "blk.{bid}.attn_norm.weight",
