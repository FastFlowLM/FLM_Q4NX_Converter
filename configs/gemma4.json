{
    "q4nx_config": {
        "row_block_size": 32,
        "col_block_size": 256,
        "parallel_size": 16,
        "keep_block_in_2D": false
    },
    "default_tensor_type": "Q4_1",
    "name_map": {
        "embedding": {
            "gguf_name": "token_embd.weight",
            "q4nx_name": "model.embed_tokens.weight"
        },
        "per_layer_token_embedding": {
            "gguf_name": "per_layer_token_embd.weight",
            "q4nx_name": "model.per_layer_token_embd.weight"
        },
        "per_layer_model_projection_weight": {
            "gguf_name": "per_layer_model_proj.weight",
            "q4nx_name": "model.per_layer_model_proj.weight",
            "default_tensor_type": "BF16"               
        },
        "per_layer_model_projection_norm": {
            "gguf_name": "per_layer_proj_norm.weight",
            "q4nx_name": "model.per_layer_proj_norm.weight",
            "default_tensor_type": "BF16"               
        },
        "q_proj": {
            "gguf_name": "blk.{bid}.attn_q.weight",
            "q4nx_name": "model.layers.{bid}.self_attn.q_proj.weight"
        },
        "q_proj_norm":{
            "gguf_name": "blk.{bid}.attn_q_norm.weight",
            "q4nx_name": "model.layers.{bid}.self_attn.q_norm.weight",
            "default_tensor_type": "BF16"            
        },
        "k_proj": {
            "gguf_name": "blk.{bid}.attn_k.weight",
            "q4nx_name": "model.layers.{bid}.self_attn.k_proj.weight"
        },
        "k_proj_norm":{
            "gguf_name": "blk.{bid}.attn_k_norm.weight",
            "q4nx_name": "model.layers.{bid}.self_attn.k_norm.weight",
            "default_tensor_type": "BF16"
        },
        "v_proj": {
            "gguf_name": "blk.{bid}.attn_v.weight",
            "q4nx_name": "model.layers.{bid}.self_attn.v_proj.weight"
        },
        "o_proj": {
            "gguf_name": "blk.{bid}.attn_output.weight",
            "q4nx_name": "model.layers.{bid}.self_attn.o_proj.weight"
        },
        "layer_output_scale" :{
            "gguf_name": "blk.{bid}.layer_output_scale.weight",
            "q4nx_name": "model.layers.{bid}.layer_output_scale.weight",
            "default_tensor_type": "BF16"                        
        },
        "per_layer_projection":{
            "gguf_name": "blk.{bid}.proj.weight",
